{
    "name": "vendor/pt",
    "description": "A simple example package managed by Composer",
    "type": "library",
    "keywords": ["example", "composer", "package"],
    "license": "MIT",
    "authors": [
        {
            "name": "Abdulrahman Basaleh",
            "email": "a.basaleh@tawasulforum.org"
        }
    ],
    "config":{
        "platform": {
            "php": "7.4.0"
        }
    },
    "scripts": {
        "make-pot": "wp i18n make-pot . languages/price-tracker.pot"
    },
    "autoload": {
        "psr-4": {
            "PriceTrackerNamespace\\settings\\": "./settings/",
            "PriceTrackerNamespace\\classes\\": "./classes/"
        }
    },
    "require-dev": {
        "wp-cli/i18n-command": "^2.6"
    }
}
